extends ../../../layouts/main

block content

  //- Tool header — breadcrumb + title
  include ../../../partials/tool-header

  .tool-layout
    .container
      .tool-layout__inner

        //- ── Main column ──────────────────────────────────────
        .tool-layout__main

          //- Error message
          if errorState && errorMessage
            .alert.alert--error(role='alert')
              p= errorMessage

          //- Input form
          form(method='POST' action=toolPath)
            .form-group
              textarea.form-textarea.form-textarea--large(
                id='text'
                name='text'
                placeholder=t('prevodVelikosti.placeholder')
                autocomplete='off'
                spellcheck='false'
              )= result || ''

            //- Conversion buttons
            .form-actions
              button.btn.btn--ghost(type='submit' name='conversionType' value='sentence-case') #{t('prevodVelikosti.sentenceCase')}
              button.btn.btn--ghost(type='submit' name='conversionType' value='lower-case') #{t('prevodVelikosti.lowerCase')}
              button.btn.btn--ghost(type='submit' name='conversionType' value='upper-case') #{t('prevodVelikosti.upperCase')}
              button.btn.btn--ghost(type='submit' name='conversionType' value='capitalized-case') #{t('prevodVelikosti.capitalizedCase')}
              button.btn.btn--ghost(type='submit' name='conversionType' value='no-diacritics') #{t('prevodVelikosti.noDiacritics')}
              button.btn.btn--ghost(type='submit' name='conversionType' value='reverse') #{t('prevodVelikosti.reverse')}

          //- Tool FAQ
          include ../../../partials/tool-faq

          //- Ad slot
          include ../../../partials/ad-slot

          //- Related tools
          include ../../../partials/tool-related

        //- ── Sidebar ──────────────────────────────────────────
        .tool-layout__sidebar

          //- Ad slot
          include ../../../partials/ad-slot

          //- About this tool
          .sidebar-info
            h3.sidebar-info__title #{t('common.aboutTool')}
            p.sidebar-info__text #{t('prevodVelikosti.sidebar.text')}
            ul.sidebar-info__list
              li #{t('prevodVelikosti.sidebar.item1')}
              li #{t('prevodVelikosti.sidebar.item2')}
              li #{t('prevodVelikosti.sidebar.item3')}

  //- Page script for live conversion
  script(src='/js/tools/case-converter.js' defer)