extends ../../../layouts/main

block content

  //- Tool header — breadcrumb + title
  include ../../../partials/tool-header

  .tool-layout
    .container
      .tool-layout__inner

        //- ── Main column ──────────────────────────────────────
        .tool-layout__main

          //- Error message
          if errorState && errorMessage
            .alert.alert--error(role='alert')
              p= errorMessage

          //- Input form
          form(method='POST' action=toolPath)
            .form-group
              textarea.form-textarea.form-textarea--large(
                id='text'
                name='text'
                placeholder=t('pocetZnaku.placeholder')
                autocomplete='off'
                spellcheck='true'
              )= text || ''

              //- Live stats — shown immediately via JS, hidden until JS runs
              .word-count-live(id='liveStats' aria-live='polite')
                .stat-grid
                  .stat-card
                    p.stat-card__value(id='stat-raw')= result ? result.textLengthRaw : 0
                    p.stat-card__label #{t('pocetZnaku.statRaw')}
                  .stat-card
                    p.stat-card__value(id='stat-nospace')= result ? result.textLengthNoSpace : 0
                    p.stat-card__label #{t('pocetZnaku.statNospace')}
                  .stat-card
                    p.stat-card__value(id='stat-words')= result ? result.wordCount : 0
                    p.stat-card__label #{t('pocetZnaku.statWords')}
                  .stat-card
                    p.stat-card__value(id='stat-sentences')= result ? result.sentenceCount : 0
                    p.stat-card__label #{t('pocetZnaku.statSentences')}
                  .stat-card
                    p.stat-card__value(id='stat-lines')= result ? result.lineCount : 0
                    p.stat-card__label #{t('pocetZnaku.statLines')}
                  .stat-card
                    p.stat-card__value(id='stat-ns')= result ? result.nsCount.toFixed(2) : '0.00'
                    p.stat-card__label #{t('pocetZnaku.statNs')}
                  .stat-card
                    p.stat-card__value(id='stat-reading')= result ? result.readingTime : 0
                    p.stat-card__label #{t('pocetZnaku.statReading')}

              button.btn.btn--primary(type='submit') #{t('common.calculate')}

          //- Tool FAQ
          include ../../../partials/tool-faq

          //- Ad slot
          include ../../../partials/ad-slot

          //- Related tools
          include ../../../partials/tool-related

        //- ── Sidebar ──────────────────────────────────────────
        .tool-layout__sidebar

          //- Ad slot
          include ../../../partials/ad-slot

          //- About this tool
          .sidebar-info
            h3.sidebar-info__title #{t('common.aboutTool')}
            p.sidebar-info__text #{t('pocetZnaku.sidebar.text')}
            ul.sidebar-info__list
              li #{t('pocetZnaku.sidebar.item1')}
              li #{t('pocetZnaku.sidebar.item2')}
              li #{t('pocetZnaku.sidebar.item3')}
              li #{t('pocetZnaku.sidebar.item4')}
              li #{t('pocetZnaku.sidebar.item5')}

  //- Page script for live counting
  script(src='/js/tools/word-count.js' defer)