extends ../../../layouts/main

block content

  include ../../../partials/tool-header

  section.tool-layout.tool-layout--compact
    .container

        //- ── Results (above forms) ──────────────────────────────

        //- Result: real inflation
        if result && inputValue && activeForm === 'real_inflation'
          .tool-result.tool-result--compact
            .tool-result__header
              span.tool-result__heading #{t('common.result')}
            .tool-result__content
              .tool-result-display
                span.tool-result-display__value= result.toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kč'
                span.tool-result-display__label #{t('inflation.resultValue')}
              table.inflation-table
                tr
                  td #{t('inflation.originalAmount')}
                  td= inputValue.toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kč'
                tr
                  td #{t('inflation.resultValue')}
                  td= result.toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kč'
                tr
                  td #{t('inflation.difference')}
                  td= (result - inputValue).toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kč'
                tr
                  td #{t('inflation.valueIncrease')}
                  td= ((result - inputValue) / inputValue * 100).toLocaleString('cs-CZ', { minimumFractionDigits: 1, maximumFractionDigits: 1 }) + ' %'

        //- Result: custom forward / backward
        if result && inputValue && (activeForm === 'custom_forward' || activeForm === 'custom_backward')
          .tool-result.tool-result--compact
            .tool-result__header
              span.tool-result__heading #{t('common.result')}
            .tool-result__content
              .tool-result-display
                span.tool-result-display__value= result.toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kč'
                if activeForm === 'custom_forward'
                  span.tool-result-display__label #{t('inflation.futureValue')}
                else
                  span.tool-result-display__label #{t('inflation.pastValue')}
              table.inflation-table
                tr
                  if activeForm === 'custom_forward'
                    td #{t('inflation.originalAmount')}
                  else
                    td #{t('inflation.todayAmount')}
                  td= inputValue.toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kč'
                tr
                  if activeForm === 'custom_forward'
                    td #{t('inflation.futureValue')}
                  else
                    td #{t('inflation.pastValue')}
                  td= result.toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kč'
                tr
                  td #{t('inflation.difference')}
                  if activeForm === 'custom_forward'
                    td= (result - inputValue).toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kč'
                  else
                    td= (inputValue - result).toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kč'
                tr
                  if activeForm === 'custom_forward'
                    td #{t('inflation.valueIncrease')}
                    td= ((result - inputValue) / inputValue * 100).toLocaleString('cs-CZ', { minimumFractionDigits: 1, maximumFractionDigits: 1 }) + ' %'
                  else
                    td #{t('inflation.purchaseLoss')}
                    td= ((inputValue - result) / inputValue * 100).toLocaleString('cs-CZ', { minimumFractionDigits: 1, maximumFractionDigits: 1 }) + ' %'

        //- Result: CAGR
        if result !== null && inputStartValue && activeForm === 'cagr'
          .tool-result.tool-result--compact
            .tool-result__header
              span.tool-result__heading #{t('common.result')}
            .tool-result__content
              .tool-result-display
                span.tool-result-display__value= result.toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' %'
                span.tool-result-display__label #{t('inflation.cagrResultLabel')}
              table.inflation-table
                tr
                  td #{t('inflation.cagrStartValue')}
                  td= inputStartValue.toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kč'
                tr
                  td #{t('inflation.cagrEndValue')}
                  td= inputEndValue.toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kč'
                tr
                  td #{t('inflation.cagrYears')}
                  td= inputYears
                tr
                  td #{t('inflation.cagrTotalGrowth')}
                  td= ((inputEndValue - inputStartValue) / inputStartValue * 100).toLocaleString('cs-CZ', { minimumFractionDigits: 1, maximumFractionDigits: 1 }) + ' %'
        
        //- Error message
        if errorMessage
          .alert.alert--error(role='alert' style='margin-bottom: var(--space-6)')
            p= errorMessage

        //- ── 1. Reálná inflace ──────────────────────────────────
        .inflation-section
          h2.inflation-section__title #{t('inflation.realTitle')}
          p.inflation-section__desc #{t('inflation.realDesc')}

          form.inflation-form(method='POST' action='')
            input(type='hidden' name='form_id' value='real_inflation')

            .form-row
              .form-group
                label.form-label(for='real-value') #{t('inflation.amountLabel')}
                input.form-input#real-value(
                  type='number'
                  name='value'
                  min='0.01'
                  step='0.01'
                  placeholder='10 000'
                  required
                  value=inputValue || ''
                )

            .form-row
              .form-group
                label.form-label(for='real-start-month') #{t('inflation.startMonthLabel')}
                select.form-select#real-start-month(name='startMonth')
                  option(value='average') #{t('inflation.months.average')}
                  option(value='1') #{t('inflation.months.1')}
                  option(value='2') #{t('inflation.months.2')}
                  option(value='3') #{t('inflation.months.3')}
                  option(value='4') #{t('inflation.months.4')}
                  option(value='5') #{t('inflation.months.5')}
                  option(value='6') #{t('inflation.months.6')}
                  option(value='7') #{t('inflation.months.7')}
                  option(value='8') #{t('inflation.months.8')}
                  option(value='9') #{t('inflation.months.9')}
                  option(value='10') #{t('inflation.months.10')}
                  option(value='11') #{t('inflation.months.11')}
                  option(value='12') #{t('inflation.months.12')}

              .form-group
                label.form-label(for='real-start-year') #{t('inflation.startYearLabel')}
                select.form-select#real-start-year(name='startYear')
                  - for (let y = 1997; y <= 2025; y++)
                    option(value=y)= y

            .form-row
              .form-group
                label.form-label(for='real-end-month') #{t('inflation.endMonthLabel')}
                select.form-select#real-end-month(name='endMonth')
                  option(value='average') #{t('inflation.months.average')}
                  option(value='1') #{t('inflation.months.1')}
                  option(value='2') #{t('inflation.months.2')}
                  option(value='3') #{t('inflation.months.3')}
                  option(value='4') #{t('inflation.months.4')}
                  option(value='5') #{t('inflation.months.5')}
                  option(value='6') #{t('inflation.months.6')}
                  option(value='7') #{t('inflation.months.7')}
                  option(value='8') #{t('inflation.months.8')}
                  option(value='9') #{t('inflation.months.9')}
                  option(value='10') #{t('inflation.months.10')}
                  option(value='11') #{t('inflation.months.11')}
                  option(value='12') #{t('inflation.months.12')}

              .form-group
                label.form-label(for='real-end-year') #{t('inflation.endYearLabel')}
                select.form-select#real-end-year(name='endYear')
                  - for (let y = 1998; y <= 2026; y++)
                    option(value=y selected=(y === 2025))= y

            button.btn.btn--primary(type='submit') #{t('inflation.calculate')}

        .inflation-divider

        //- ── 2. Vlastní sazba ───────────────────────────────────
        .inflation-section
          h2.inflation-section__title #{t('inflation.customTitle')}
          p.inflation-section__desc #{t('inflation.customDesc')}

          form.inflation-form(method='POST' action='')
            input(type='hidden' name='form_id' value='custom_inflation')

            .form-row
              .form-group
                label.form-label(for='custom-value') #{t('inflation.amountLabel')}
                input.form-input#custom-value(
                  type='number'
                  name='value'
                  min='0.01'
                  step='0.01'
                  placeholder='10 000'
                  value=inputValue || ''
                  required
                )
              .form-group
                label.form-label(for='custom-rate') #{t('inflation.rateLabel')}
                input.form-input#custom-rate(
                  type='number'
                  name='inflationRate'
                  min='0'
                  step='0.1'
                  placeholder='3'
                  value=inputInflationRate || ''
                  required
                )
              .form-group
                label.form-label(for='custom-years') #{t('inflation.yearsLabel')}
                input.form-input#custom-years(
                  type='number'
                  name='years'
                  min='0'
                  step='1'
                  placeholder='10'
                  value=inputYears || ''
                  required
                )

            .form-actions
              button.btn.btn--primary(type='submit' name='type' value='forward') #{t('inflation.calculateForward')}
              button.btn.btn--ghost(type='submit' name='type' value='backward') #{t('inflation.calculateBackward')}

        .inflation-divider

        //- ── 3. CAGR — průměrný roční výnos ─────────────────────
        .inflation-section
          h2.inflation-section__title #{t('inflation.cagrTitle')}
          p.inflation-section__desc #{t('inflation.cagrDesc')}

          form.inflation-form(method='POST' action='')
            input(type='hidden' name='form_id' value='cagr')

            .form-row
              .form-group
                label.form-label(for='cagr-start-value') #{t('inflation.startValueLabel')}
                input.form-input#cagr-start-value(
                  type='number'
                  name='startValue'
                  min='0.01'
                  step='0.01'
                  placeholder='3 500 000'
                  value=inputStartValue || ''
                  required
                )
              .form-group
                label.form-label(for='cagr-end-value') #{t('inflation.endValueLabel')}
                input.form-input#cagr-end-value(
                  type='number'
                  name='endValue'
                  min='0.01'
                  step='0.01'
                  placeholder='11 000 000'
                  value=inputEndValue || ''
                  required
                )
              .form-group
                label.form-label(for='cagr-years') #{t('inflation.yearsLabel')}
                input.form-input#cagr-years(
                  type='number'
                  name='years'
                  min='1'
                  step='1'
                  placeholder='10'
                  value=inputYears || ''
                  required
                )

            button.btn.btn--primary(type='submit') #{t('inflation.calculateCagr')}

        .inflation-divider

    //- FAQ
    include ../../../partials/tool-faq

    //- Ad slot
    include ../../../partials/ad-slot

    //- Related tools
    include ../../../partials/tool-related