extends ../../../layouts/main

block content
  .legal-page
    .container
      .legal-page__header
        h1.legal-page__title #{ t('common:contact.title') }
        p.legal-page__meta #{ t('common:contact.page.subtitle') }

      .contact-grid
        .contact-info
          section.legal-section
            h2 #{ t('common:contact.about.title') }
            p #{ t('common:contact.about.p1', { siteName: siteName }) }
            p #{ t('common:contact.about.p2') }
            p #{ t('common:contact.about.p3') }

          section.legal-section
            h2 #{ t('common:contact.when.title') }
            ul
              li #{ t('common:contact.when.item1') }
              li #{ t('common:contact.when.item2') }
              li #{ t('common:contact.when.item3') }
              li #{ t('common:contact.when.item4') }

          section.legal-section
            h2 #{ t('common:contact.docs.title') }
            ul
              li: a(href=`/${lang}/privacy`) #{ t('common:contact.docs.privacy') }
              li: a(href=`/${lang}/terms`) #{ t('common:contact.docs.terms') }

        .contact-form-wrap
          h2 #{ t('common:contact.form.title') }

          form.contact-form(method="POST" action="https://formspree.io/f/xwvznbel")
            input(type="hidden" name="_next" value=`${siteUrl}/${lang}/contact?success=true`)

            .form-group
              label.form-label(for="name") #{ t('common:contact.form.name.label') }
              input#name.form-input(
                type="text"
                name="name"
                placeholder=t("common:contact.form.name.placeholder")
                required
                autocomplete="name"
              )

            .form-group
              label.form-label(for="email") #{ t('common:contact.form.email.label') }
              input#email.form-input(
                type="email"
                name="email"
                placeholder=t("common:contact.form.email.placeholder")
                required
                autocomplete="email"
              )

            .form-group
              label.form-label(for="subject") #{ t('common:contact.form.subject.label') }
              select#subject.form-select(name="subject")
                option(value=t("common:contact.form.subject.bug")) #{ t('common:contact.form.subject.bug') }
                option(value=t("common:contact.form.subject.improvement")) #{ t('common:contact.form.subject.improvement') }
                option(value=t("common:contact.form.subject.privacy")) #{ t('common:contact.form.subject.privacy') }
                option(value=t("common:contact.form.subject.other")) #{ t('common:contact.form.subject.other') }

            .form-group
              label.form-label(for="message") #{ t('common:contact.form.message.label') }
              textarea#message.form-textarea(
                name="message"
                placeholder=t("common:contact.form.message.placeholder")
                rows="6"
                required
              )

            .form-group
              button.btn.btn--primary(type="submit") #{ t('common:contact.form.submit') }
              p.form-hint #{ t('common:contact.form.hint') }
