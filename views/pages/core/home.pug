extends ../../layouts/main

block content
  //- ── Hero ───────────────────────────────────────────────
  section.hero
    .container
      .hero__inner
        .hero__text
          h1.hero__title
            | #{ t('home.hero.titleLine1') }
            br
            span.hero__title-accent #{ t('home.hero.titleAccent') }
          p.hero__subtitle #{ t('home.hero.subtitle') }
          .hero__actions
            a.btn.btn--primary.btn--lg(href=`/${lang}/tools`) #{ t('home.hero.cta') }
            a.btn.btn--ghost-inverse.btn--lg(href=`/${lang}#nastroje`) #{ t('home.hero.ctaSecondary') }

        //- Right — stats mosaic (move block below to the left to un-comment)
          .hero__stats-grid
            .hero__stat-card.hero__stat-card--wide
              span.hero__stat-number 100+
              span.hero__stat-label Bezplatných nástrojů
              p.hero__stat-desc Od textových nástrojů přes PDF a obrázky až po česká data.
            .hero__stat-card
              span.hero__stat-number 0
              span.hero__stat-label Registrací
            .hero__stat-card
              span.hero__stat-number 🇨🇿
              span.hero__stat-label Lokální data

  //- ── Featured tools ──────────────────────────────────────
  section#nastroje.featured-tools
    .container
      .section-header
        h2.section-title #{ t('home.featured.title') }
        a.section-link(href=`/${lang}/tools`) #{ t('home.featured.viewAll') }
      .tools-grid
        each tool in tools
          if tool.enabled[lang]
            a.tool-card(href=tool.resolvedPath)
              .tool-card__icon= tool.icon
              .tool-card__body
                h3.tool-card__name= tool.resolvedTitle
                p.tool-card__desc= tool.resolvedDescription
              span.tool-card__tag= tool.resolvedCategoryName
          else
            .tool-card.tool-card--disabled
              .tool-card__icon= tool.icon
              .tool-card__body
                h3.tool-card__name= tool.resolvedTitle
                p.tool-card__desc= tool.resolvedDescription
              span.tool-card__tag #{ t('home.featured.comingSoon') }

  //- ── Features ─────────────────────────────────────────────
  section.features-section
    .container
      .section-header
        h2.section-title #{ t('home.features.title') }
      .features-grid
        .feature-item
          .feature-item__icon 🧮
          h3.feature-item__title #{ t('home.features.calculators.title') }
          p.feature-item__desc #{ t('home.features.calculators.desc') }
        .feature-item
          .feature-item__icon 🔒
          h3.feature-item__title #{ t('home.features.privacy.title') }
          p.feature-item__desc #{ t('home.features.privacy.desc') }
        .feature-item
          .feature-item__icon ⚡
          h3.feature-item__title #{ t('home.features.speed.title') }
          p.feature-item__desc #{ t('home.features.speed.desc') }

  //- ── FAQ teaser ───────────────────────────────────────────
  section.faq-teaser
    .container
      .faq-teaser__inner
        .faq-teaser__text
          h2.section-title #{ t('common:home.faqTeaser.title') }
          p.faq-teaser__desc #{ t('common:home.faqTeaser.desc') }
          a.btn.btn--primary(href=`/${lang}/faq`) #{ t('common:home.faqTeaser.cta') }

        .faq-list
          details.faq-item
            summary.faq-question #{ t('common:home.faqTeaser.q1.question') }
            p.faq-answer #{ t('common:home.faqTeaser.q1.answer') }

          details.faq-item
            summary.faq-question #{ t('common:home.faqTeaser.q2.question') }
            p.faq-answer #{ t('common:home.faqTeaser.q2.answer') }
