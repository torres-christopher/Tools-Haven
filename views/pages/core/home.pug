extends ../../layouts/main

block content
  //- ── Hero ───────────────────────────────────────────────
  section.hero
    .container
      .hero__inner
        .hero__text
          h1.hero__title
            | Bezplatné české
            br
            span.hero__title-accent online nástroje.
          p.hero__subtitle
            | Úprava textu, validace kódu, česká data
            | zdarma, bez registrace.
          .hero__actions
            a.btn.btn--primary.btn--lg(href="/vsechny-nastroje") Procházet nástroje
            a.btn.btn--ghost-inverse.btn--lg(href="/#nastroje") Nejoblíbenější

        //- Right — stats mosaic (move block below to the left to un-comment)
          .hero__stats-grid
            .hero__stat-card.hero__stat-card--wide
              span.hero__stat-number 100+
              span.hero__stat-label Bezplatných nástrojů
              p.hero__stat-desc Od textových nástrojů přes PDF a obrázky až po česká data.
            .hero__stat-card
              span.hero__stat-number 0
              span.hero__stat-label Registrací
            .hero__stat-card
              span.hero__stat-number 🇨🇿
              span.hero__stat-label Lokální data

  //- ── Featured tools ──────────────────────────────────────
  section#nastroje.featured-tools
    .container
      .section-header
        h2.section-title Nejoblíbenější nástroje
        a.section-link(href="/vsechny-nastroje") Zobrazit vše →
      .tools-grid
        each tool in tools
          if tool.enabled
            a.tool-card(href=tool.path)
              .tool-card__icon= tool.icon
              .tool-card__body
                h3.tool-card__name= tool.title
                p.tool-card__desc= tool.description
              span.tool-card__tag= tool.categoryName
          else
            .tool-card.tool-card--disabled
              .tool-card__icon= tool.icon
              .tool-card__body
                h3.tool-card__name= tool.title
                p.tool-card__desc= tool.description
              span.tool-card__tag Připravujeme

  //- ── Features ─────────────────────────────────────────────
  section.features-section
    .container
      .section-header
        h2.section-title Co tento web nabízí
      .features-grid
        .feature-item
          .feature-item__icon 🧮
          h3.feature-item__title Kalkulačky a převodníky
          p.feature-item__desc
            | Zdravotní kalkulačky, převodníky jednotek, datum a čas,
            | číslenicové soustavy, ASCII, barvy a kódování.
        .feature-item
          .feature-item__icon 🔒
          h3.feature-item__title Soukromí na prvním místě
          p.feature-item__desc
            | Data nejsou ukládána ani sdílena. Soubory jsou zpracovány
            | v paměti serveru a po výsledku okamžitě smazány.
        .feature-item
          .feature-item__icon ⚡
          h3.feature-item__title Rychlé a bez překážek
          p.feature-item__desc
            | Žádná registrace, žádné přihlašování. Otevřete nástroj
            | a okamžitě pracujete. Funguje na mobilu i desktopu.

  //- ── FAQ teaser ───────────────────────────────────────────
  section.faq-teaser
    .container
      .faq-teaser__inner
        .faq-teaser__text
          h2.section-title Časté dotazy
          p.faq-teaser__desc
            | Odpovídáme na nejčastější otázky o fungování nástrojů,
            | ochraně soukromí a dostupnosti dat.
          a.btn.btn--primary(href="/faq") Všechny dotazy →

        .faq-list
          details.faq-item
            summary.faq-question Je použití nástrojů zdarma?
            p.faq-answer
              | Ano, všechny nástroje jsou zcela bezplatné a nevyžadují
              | žádnou registraci ani zadání platebního údaje.

          details.faq-item
            summary.faq-question Co se děje s daty, které nahraji?
            p.faq-answer
              | Data jsou zpracována v paměti serveru a po výsledku okamžitě
              | smazána. Nic neukládáme ani nesdílíme s třetími stranami.
