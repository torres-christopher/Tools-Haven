nav.site-nav
  ul.site-nav__list
    li.site-nav__item
      a.site-nav__link(href=`/${lang}/tools`) #{ t('common:nav.allTools') }

    //- Text tools
    li.site-nav__item.site-nav__item--dropdown
      button.site-nav__link.site-nav__dropdown-toggle(aria-expanded="false") #{ t('common:nav.category.text.title') }
        svg(width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true")
          path(
            d="M2 4l4 4 4-4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          )
      ul.site-nav__dropdown
        //- TODO: tool slugs in nav should be driven by tools registry once nav is data-driven
        if lang === "sk"
          li: a(href=`/${lang}/text/pocet-znakov`) #{ t('common:nav.category.text.wordCount') }
          li: a(href=`/${lang}/text/prevod-velkosti-znakov`) #{ t('common:nav.category.text.caseConverter') }
        else
          li: a(href=`/${lang}/text/pocet-znaku`) #{ t('common:nav.category.text.wordCount') }
          li: a(href=`/${lang}/text/prevod-velikosti-znaku`) #{ t('common:nav.category.text.caseConverter') }
    
    //- Developer tools
    li.site-nav__item.site-nav__item--dropdown
      button.site-nav__link.site-nav__dropdown-toggle(aria-expanded="false") #{ t('common:nav.category.developer.title') }
        svg(width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true")
          path(
            d="M2 4l4 4 4-4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          )
      ul.site-nav__dropdown
        li: a(href=`/${lang}/developer/json-validator`) #{ t('common:nav.category.developer.jsonValidator') }

    //- Datetime tools
    li.site-nav__item.site-nav__item--dropdown
      button.site-nav__link.site-nav__dropdown-toggle(aria-expanded="false") #{ t('common:nav.category.datetime.title') }
        svg(width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true")
          path(
            d="M2 4l4 4 4-4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          )
      ul.site-nav__dropdown        
        if lang === "sk"
          li: a(href=`/${lang}/datetime/datumova-kalkulacka`) #{ t('common:nav.category.datetime.dateCalculator') }
        else
          li: a(href=`/${lang}/datetime/datumovy-kalkulator`) #{ t('common:nav.category.datetime.dateCalculator') }
        li: a(href=`/${lang}/datetime/kalkulacka-veku`) #{ t('common:nav.category.datetime.ageCalculator') }
    
    //- Health tools
    li.site-nav__item.site-nav__item--dropdown
      button.site-nav__link.site-nav__dropdown-toggle(aria-expanded="false") #{ t('common:nav.category.health.title') }
        svg(width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true")
          path(
            d="M2 4l4 4 4-4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          )
      ul.site-nav__dropdown
        li: a(href=`/${lang}/health/bmi-kalkulacka`) #{ t('common:nav.category.health.bmiKalkulacka') }
    
    //- Local tools
    li.site-nav__item.site-nav__item--dropdown
      button.site-nav__link.site-nav__dropdown-toggle(aria-expanded="false") #{ t('common:nav.category.local.title') }
        svg(width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true")
          path(
            d="M2 4l4 4 4-4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          )
      ul.site-nav__dropdown
        //- TODO: tool slugs in nav should be driven by tools registry once nav is data-driven
        if lang === "sk"
          li: a(href=`/${lang}/local/inflacna-kalkulacka`) #{ t('common:nav.category.local.inflacniKalkulacka') }
        else
          li: a(href=`/${lang}/local/inflacni-kalkulacka`) #{ t('common:nav.category.local.inflacniKalkulacka') }
